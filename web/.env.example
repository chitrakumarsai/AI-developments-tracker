# AI Chronicles — environment variables. Copy to .env.local and fill in.
# NEVER commit real secrets. Only NEXT_PUBLIC_* values reach the browser.

# --- Supabase ---------------------------------------------------------------
# From the Supabase project dashboard (Cloud) or `supabase start` (local).
# Settings → API: Project URL + anon/publishable key + service-role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Full access — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (Phase 2.1) -------------------------------------------------------
# Canonical public origin, used to build the OAuth/magic-link callback URL so it
# is never derived from an attacker-controlled Host header. Leave blank for local
# dev (falls back to the request host); set it in preview/prod, e.g.
# https://ai-chronicles.vercel.app  — no trailing slash needed.
NEXT_PUBLIC_SITE_URL=
# Owner allowlist: the email(s) granted the `owner` role (source-catalog write).
# Comma-separated for more than one. Matched case-insensitively against the
# verified session email. Server-side only.
OWNER_EMAIL=
# Sign-in providers are enabled in the Supabase dashboard (Auth → Providers):
#   • Email (magic link) — on by default.
#   • GitHub OAuth  — register an OAuth app, paste Client ID/Secret into Supabase.
#   • Google OAuth  — create OAuth credentials, paste Client ID/Secret into Supabase.
# Add the callback URL <origin>/auth/callback to each provider's allowed redirects
# AND to Supabase Auth → URL Configuration → Redirect URLs. No provider secrets
# live in this app — Supabase holds them.

# --- Source APIs ------------------------------------------------------------
# GitHub Search API (Companies/Repos ingestion). Server-side only. A classic
# or fine-grained PAT with public-repo read is enough for search.
GITHUB_TOKEN=

# Hugging Face — daily papers + trending models. Server-side only. Optional:
# the endpoints are public, but a read token raises rate limits.
HUGGINGFACE_TOKEN=

# --- OpenAI -----------------------------------------------------------------
# Used for item summaries + relevance scoring (introduced in subphase 1.4).
# Models: gpt-4o (quality passes) + gpt-4o-mini (bulk scoring).
OPENAI_API_KEY=
OPENAI_MODEL_QUALITY=gpt-4o
OPENAI_MODEL_BULK=gpt-4o-mini

# --- Cron ------------------------------------------------------------------
# Shared secret guarding the scheduled-refresh route (subphase 1.3).
CRON_SECRET=

# --- Rate limiting (Upstash Redis — Phase 2.3) ------------------------------
# Optional. Throttles write endpoints (/api/feedback, /api/candidates/*, cron).
# Provision the free tier via Vercel Marketplace → Storage → Upstash: it injects
# KV_REST_API_URL/KV_REST_API_TOKEN automatically (the code reads those). For a
# manual (non-Vercel) setup from console.upstash.com, use the UPSTASH_* names
# below instead. When neither pair is present the limiter fails OPEN (no
# throttling) — the app still works, just unprotected.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Set automatically by the Vercel Upstash/KV integration (leave blank locally):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
