# Sonar — environment variables. Copy to .env.local and fill in.
# NEVER commit real secrets. Only NEXT_PUBLIC_* values reach the browser.

# --- Supabase ---------------------------------------------------------------
# From the Supabase project dashboard (Cloud) or `supabase start` (local).
# Settings → API: Project URL + anon/publishable key + service-role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Full access — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI -----------------------------------------------------------------
# Used for item summaries + relevance scoring (introduced in subphase 1.4).
# Models: gpt-4o (quality passes) + gpt-4o-mini (bulk scoring).
OPENAI_API_KEY=
OPENAI_MODEL_QUALITY=gpt-4o
OPENAI_MODEL_BULK=gpt-4o-mini

# --- Cron ------------------------------------------------------------------
# Shared secret guarding the scheduled-refresh route (subphase 1.3).
CRON_SECRET=
